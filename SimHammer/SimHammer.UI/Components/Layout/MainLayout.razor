@inherits LayoutComponentBase

<div class="app-shell">
    <nav class="nav-bar">
        <div class="navbar-brand">
            <div class="navbar-title-group">
                <span class="navbar-title"><i>+</i>SimHammer</span>
                <span class="navbar-subtitle">Combat Simulation Of The Far Future</span>
            </div>
        </div>

        <div class="navbar-links">
            <NavMenu />
        </div> 

        <div class="edition-disclaimer">
            <span>For Warhammer 40K 10th Edition</span>
        </div>
    </nav>

    <main class="main-content">
        @Body
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
